# =============================================================================
# RemotePKJobs — Environment Variables
# Copy to .env and fill in values. Never commit real secrets.
# =============================================================================

# --- Application ---
APP_NAME=RemotePKJobs
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://127.0.0.1:8000
APP_TIMEZONE=UTC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# --- Logging ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# --- Database (MySQL on Ubuntu production) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=remotepkjobs
DB_USERNAME=remotepkjobs
DB_PASSWORD=

# --- Session / Cache / Queue (Redis recommended in production) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# --- Redis ---
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Internal API (required for Python agents → Laravel) ---
# Shared secret sent as X-Internal-Token header from python/agents/*.py
INTERNAL_API_TOKEN=

# --- Admin panel (http://127.0.0.1:8000/admin/login) ---
ADMIN_PASSWORD=

# --- GitHub API (required for github_updater.py — higher rate limits) ---
# Create at https://github.com/settings/tokens (read-only public_repo scope is enough)
GITHUB_TOKEN=

# --- Blog hero images (Pollinations AI — free, no API key) ---
BLOG_IMAGE_WIDTH=1640
BLOG_IMAGE_HEIGHT=720

# --- Exchange rates ---
# Free tier (no key): https://open.er-api.com/v6/latest/USD
# Paid exchangerate-api.com v6: https://v6.exchangerate-api.com/v6/YOUR_KEY/latest/USD
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest/USD
EXCHANGE_RATE_API_KEY=

# --- Python (Windows local dev only — Linux uses python/venv/bin/python) ---
PYTHON_PATH=python

# --- Mail ---
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- AWS (optional — not required for core DevRates) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Vite frontend build ---
VITE_APP_NAME="${APP_NAME}"
